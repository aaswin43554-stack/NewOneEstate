# ─── Database (Supabase project: vwfhfwalordokexplpqh, ap-northeast-1) ────────
# Get this from: Supabase Dashboard → Project → Settings → Database → Connection string → URI
# Use the DIRECT connection (port 5432), NOT the pooler port 6543.
# Reason: we use SET search_path per connection, which requires session-mode.
#
# Format: postgresql://postgres:[YOUR-DB-PASSWORD]@db.vwfhfwalordokexplpqh.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[YOUR-DB-PASSWORD]@db.vwfhfwalordokexplpqh.supabase.co:5432/postgres

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Client ──────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
